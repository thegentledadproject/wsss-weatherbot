# ══════════════════════════════════════════════════════════════════════════
# IMPORTANT: this file is loaded TWO different ways depending on how you run
# Hermes, and they parse comments differently:
#   - Local/manual runs (`python scheduler.py`) use python-dotenv, which
#     strips inline "# comment" text after a value.
#   - Production runs (via systemd, the documented deploy path) use
#     systemd's own EnvironmentFile= parser, which does NOT support inline
#     comments — everything after "=" on a line becomes part of the literal
#     value, comment text included. Confirmed: systemd/systemd issue #12527.
# For that reason every line below uses a comment on its OWN line, never
# trailing on the same line as a value. When you edit this file, follow the
# same pattern — do not add "KEY=value # comment" on one line.
# ══════════════════════════════════════════════════════════════════════════

# Polymarket CLOB credentials
# Private key: from polymarket.com/settings -> Export Private Key
POLYMARKET_PRIVATE_KEY=0x...
# Deposit wallet address: from polymarket.com/settings
POLYMARKET_FUNDER=0x...
# 0 = MetaMask/EOA, 1 = email/Magic proxy wallet, 3 = deposit wallet (ERC-1967
# proxy — see setup_deposit_wallet.py). Since Polymarket's CLOB V2 go-live,
# 0 and 1 are both rejected ("maker address not allowed, please use the
# deposit wallet flow") — 3 is the only working option as of this writing.
POLYMARKET_SIGNATURE_TYPE=3
# All three generated by running: python generate_creds.py
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# CLOB API host — override only if Polymarket changes their endpoint or
# you're pointing at a staging/alternate host. Default matches production.
CLOB_API_HOST=https://clob.polymarket.com

# Builder credentials — ONLY needed to run setup_deposit_wallet.py (one-time
# deposit-wallet provisioning), not by the live bot. Get these at
# polymarket.com/settings?tab=builder
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASS_PHRASE=
# Relayer endpoint used by setup_deposit_wallet.py — override only for
# Polymarket's staging environment.
RELAYER_URL=https://relayer-v2.polymarket.com

# Vault — no longer used for position sizing (Kelly/vault-based sizing is
# disabled in scheduler.py; every trade uses the fixed order size below
# instead). Still read by dashboard_api.py as the starting-capital baseline
# for the P&L/ROI display, so keep this set to a realistic figure.
MAX_VAULT_ALLOCATION=200.0

# Edge threshold (8% = 0.08, raised from 0.05 for win-rate selectivity).
# Filters entries to higher-conviction signals. Tradeoff: fewer total
# trades, lower throughput. No longer affects stop-loss distance — that's
# STOP_LOSS_PCT below (core/position_monitor.py), decoupled after a fixed-$
# stop gave a cheap long-shot entry a 56% drawdown tolerance vs ~5-10% for
# a normally-priced one, from the same nominal distance.
EDGE_THRESHOLD=0.08

# Max tradeable edge magnitude (50% = 0.50) — signals beyond this are gated
# (SKIP_EXTREME_EDGE) rather than traded. An edge this large has repeatedly
# turned out to mean the model's sigma was too tight relative to its own
# calibration history, not that a huge mispricing was found — see
# core/model.py's historical_sigma blending, added for the same root cause.
MAX_EDGE_MAGNITUDE=0.50

# Minimum entry price (15 cents = 0.15) — tokens priced below this are gated
# (SKIP_LOW_PRICE) regardless of edge. Cheap long-shot tokens need far more
# shares to fill the same $ notional, and that's exactly the segment where
# entry-time liquidity checks are least predictive of exit-time slippage —
# confirmed in production: a 30°C:YES position entered at 0.05 passed the
# standard liquidity floor, then stopped out at 0.03 (a 40% realized loss
# against a 10% STOP_LOSS_PCT target) purely from thin-book slippage.
MIN_ENTRY_PRICE=0.15

# Tokens priced below this (15 cents = 0.15) would require a higher liquidity
# floor than normal (LOW_PRICE_LIQUIDITY_FLOOR) — same rationale as
# MIN_ENTRY_PRICE above. Set equal to MIN_ENTRY_PRICE by choice: this makes
# the raised-floor check dead code (MIN_ENTRY_PRICE already blocks everything
# it would otherwise apply to) — kept at the same value rather than removed
# so it's a one-line change to reopen a graduated band below MIN_ENTRY_PRICE
# later (set LOW_PRICE_THRESHOLD above MIN_ENTRY_PRICE) without re-deriving
# the mechanism from scratch.
LOW_PRICE_THRESHOLD=0.15
LOW_PRICE_LIQUIDITY_FLOOR=25.0

# ── Kelly sizing (core/sizing.py::compute_size) — currently UNUSED ──────────
# scheduler.py now sizes every trade with the fixed order size below instead
# of calling compute_size(). These are kept so Kelly sizing can be re-enabled
# later (repoint scheduler.py's Job 3 back to compute_size) without having to
# re-derive good defaults.
MIN_POSITION_USD=2.0
KELLY_FRACTION=0.50
SMALL_EV_HURDLE=0.08

# Trailing stop: % drawdown from peak before exit (20% = 0.20)
TRAIL_PCT=0.20

# Stop loss: % drawdown from ENTRY (not peak) before exit (10% = 0.10).
# Percentage-of-entry, not a fixed $ delta — a 0.089 entry and a 0.81 entry
# both get the same 10% real drawdown protection. Previously this reused
# EDGE_THRESHOLD as a flat $ distance subtracted from entry, which gave a
# cheap long-shot entry a far larger real drawdown tolerance (56%) than an
# expensive one (~6-10%) for the same nominal distance.
STOP_LOSS_PCT=0.10

# ── Fixed order size (Kelly/vault sizing disabled) ───────────────────────────
# Every actionable signal trades at this fixed USD size via
# core.sizing.compute_validation_size() — no Kelly fraction, no vault-relative
# cap/floor, no net-EV/fee hurdle. Only core/edge.py's own gates (threshold,
# extreme-edge, liquidity, spread) decide whether a signal is actionable.
VALIDATION_POSITION_USD=1.00

# Max shares per position (15) — caps the fixed $ notional above for cheap
# entries, since the same $ notional implies more shares the cheaper the
# price ($1 at 0.05 = 20 shares vs $1 at 0.50 = 2 shares). More shares means
# a bigger order to walk out of the book on exit — capping shares directly
# bounds that exposure regardless of how liquidity has moved since entry.
MAX_SHARES_PER_POSITION=15

# DB path
DB_PATH=hermes.db
